    "expo-sqlite": "^55.0.11",
    "expo-status-bar": "~3.0.8",
    "lucide-react-native": "^0.577.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1314.0",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
